{% doc %}
  @prompt
    SLIDESHOW OF PICTURES, 3 ON PAGE AT A TIME, Make mobile layout controls 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-slideshow-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    position: relative;
    overflow: hidden;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
  }

  .ai-slideshow-container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-slideshow-track-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.image_gap }}px;
    transition: transform 0.5s ease;
  }

  .ai-slideshow-slide-{{ ai_gen_id }} {
    flex: 0 0 calc((100% - ({{ block.settings.image_gap }}px * 2)) / 3);
    position: relative;
  }

  .ai-slideshow-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: {{ block.settings.image_aspect_ratio }};
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-slideshow-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-slideshow-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-slideshow-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
  }

  .ai-slideshow-controls-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 20px;
    margin-top: {{ block.settings.controls_spacing }}px;
  }

  .ai-slideshow-button-{{ ai_gen_id }} {
    width: {{ block.settings.button_size }}px;
    height: {{ block.settings.button_size }}px;
    border-radius: 50%;
    background-color: {{ block.settings.button_color }};
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.3s ease, transform 0.2s ease;
  }

  .ai-slideshow-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
    transform: scale(1.1);
  }

  .ai-slideshow-button-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-slideshow-button-{{ ai_gen_id }}:disabled:hover {
    transform: scale(1);
  }

  .ai-slideshow-button-{{ ai_gen_id }} svg {
    width: calc({{ block.settings.button_size }}px * 0.5);
    height: calc({{ block.settings.button_size }}px * 0.5);
    fill: {{ block.settings.button_icon_color }};
  }

  .ai-slideshow-dots-{{ ai_gen_id }} {
    display: flex;
    gap: 8px;
  }

  .ai-slideshow-dot-{{ ai_gen_id }} {
    width: {{ block.settings.dot_size }}px;
    height: {{ block.settings.dot_size }}px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    border: none;
    cursor: pointer;
    transition: background-color 0.3s ease, transform 0.2s ease;
  }

  .ai-slideshow-dot-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.dot_active_color }};
    transform: scale(1.2);
  }

  .ai-slideshow-dot-{{ ai_gen_id }}:hover {
    transform: scale(1.1);
  }

  @media screen and (max-width: 749px) {
    .ai-slideshow-slide-{{ ai_gen_id }} {
      {% if block.settings.columns_mobile == '1' %}
        flex: 0 0 100%;
      {% else %}
        flex: 0 0 calc((100% - {{ block.settings.mobile_image_gap }}px) / 2);
      {% endif %}
    }

    .ai-slideshow-track-{{ ai_gen_id }} {
      gap: {{ block.settings.mobile_image_gap }}px;
    }
  }
{% endstyle %}

<image-slideshow-{{ ai_gen_id }} 
  class="ai-slideshow-{{ ai_gen_id }}" 
  data-mobile-columns="{{ block.settings.columns_mobile }}"
  data-mobile-gap="{{ block.settings.mobile_image_gap }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-slideshow-container-{{ ai_gen_id }}">
    <div class="ai-slideshow-track-{{ ai_gen_id }}">
      {% for i in (1..9) %}
        {% liquid
          assign image_key = 'image_' | append: i
          assign alt_key = 'alt_' | append: i
          assign image = block.settings[image_key]
          assign slide_alt = block.settings[alt_key]
          if slide_alt == blank
            assign slide_alt = image.alt
          endif
        %}
        <div class="ai-slideshow-slide-{{ ai_gen_id }}" data-slide-index="{{ forloop.index0 }}">
          <div class="ai-slideshow-image-wrapper-{{ ai_gen_id }}">
            {% if image %}
              {%- if slide_alt == blank -%}
                {%- comment -%} TODO alt text: {{ image.src | split: '/' | last }} {%- endcomment -%}
              {%- endif -%}
              <img
                src="{{ image | image_url: width: 800 }}"
                alt="{{ slide_alt | escape }}"
                loading="lazy"
                width="{{ image.width }}"
                height="{{ image.height }}"
                class="ai-slideshow-image-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="ai-slideshow-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>

    <div class="ai-slideshow-controls-{{ ai_gen_id }}">
      <button
        class="ai-slideshow-button-{{ ai_gen_id }} ai-slideshow-prev-{{ ai_gen_id }}"
        aria-label="Previous slide"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
          <path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/>
        </svg>
      </button>

      <div class="ai-slideshow-dots-{{ ai_gen_id }}"></div>

      <button
        class="ai-slideshow-button-{{ ai_gen_id }} ai-slideshow-next-{{ ai_gen_id }}"
        aria-label="Next slide"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
          <path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/>
        </svg>
      </button>
    </div>
  </div>
</image-slideshow-{{ ai_gen_id }}>

<script>
  (function() {
    class ImageSlideshow{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.totalSlides = 9;
        this.slidesPerView = 3;
        this.isMobile = window.innerWidth <= 749;
      }

      connectedCallback() {
        this.track = this.querySelector('.ai-slideshow-track-{{ ai_gen_id }}');
        this.slides = this.querySelectorAll('.ai-slideshow-slide-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.ai-slideshow-prev-{{ ai_gen_id }}');
        this.nextButton = this.querySelector('.ai-slideshow-next-{{ ai_gen_id }}');
        this.dotsContainer = this.querySelector('.ai-slideshow-dots-{{ ai_gen_id }}');
        this.mobileColumns = parseInt(this.dataset.mobileColumns);
        this.mobileGap = parseInt(this.dataset.mobileGap);

        this.checkMobile();
        this.createDots();
        this.updateSlideshow();
        this.setupEventListeners();
      }

      checkMobile() {
        this.isMobile = window.innerWidth <= 749;
        this.slidesPerView = this.isMobile ? this.mobileColumns : 3;
      }

      createDots() {
        this.dotsContainer.innerHTML = '';
        const maxIndex = this.totalSlides - this.slidesPerView;
        
        for (let i = 0; i <= maxIndex; i++) {
          const dot = document.createElement('button');
          dot.classList.add('ai-slideshow-dot-{{ ai_gen_id }}');
          dot.setAttribute('aria-label', `Go to slide ${i + 1}`);
          dot.addEventListener('click', () => this.goToSlide(i));
          this.dotsContainer.appendChild(dot);
        }
      }

      setupEventListeners() {
        this.prevButton.addEventListener('click', () => this.prevSlide());
        this.nextButton.addEventListener('click', () => this.nextSlide());

        window.addEventListener('resize', () => {
          const wasMobile = this.isMobile;
          this.checkMobile();
          if (wasMobile !== this.isMobile) {
            this.currentIndex = 0;
            this.createDots();
            this.updateSlideshow();
          }
        });
      }

      prevSlide() {
        if (this.currentIndex > 0) {
          this.currentIndex--;
          this.updateSlideshow();
        }
      }

      nextSlide() {
        const maxIndex = this.totalSlides - this.slidesPerView;
        if (this.currentIndex < maxIndex) {
          this.currentIndex++;
          this.updateSlideshow();
        }
      }

      goToSlide(index) {
        this.currentIndex = index;
        this.updateSlideshow();
      }

      updateSlideshow() {
        const slideWidth = this.slides[0].offsetWidth;
        const gap = this.isMobile ? this.mobileGap : {{ block.settings.image_gap }};
        const offset = -(this.currentIndex * (slideWidth + gap));
        
        this.track.style.transform = `translateX(${offset}px)`;

        const maxIndex = this.totalSlides - this.slidesPerView;
        this.prevButton.disabled = this.currentIndex === 0;
        this.nextButton.disabled = this.currentIndex === maxIndex;

        const dots = this.dotsContainer.querySelectorAll('.ai-slideshow-dot-{{ ai_gen_id }}');
        dots.forEach((dot, index) => {
          if (index === this.currentIndex) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });
      }
    }

    customElements.define('image-slideshow-{{ ai_gen_id }}', ImageSlideshow{{ ai_gen_id }});
  })();
</script>

