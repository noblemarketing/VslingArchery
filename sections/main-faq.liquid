{{ 'section-main-page.css' | asset_url | stylesheet_tag }}
{{ 'component-accordion.css' | asset_url | stylesheet_tag }}
{{ 'component-site-faq.css' | asset_url | stylesheet_tag }}

{%- include 'vsling-handles' -%}

{%- liquid
  assign bow_product_url = vsling_bow_url
  assign comparison_page_url = vsling_comparison_url
-%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="page-width page-width--narrow section-{{ section.id }}-padding color-{{ section.settings.color_scheme }} gradient">
  <header class="site-faq__header{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
    <h1 id="SiteFaqHeading" class="main-page-title page-title h0">
      {{ section.settings.heading | default: 'Vsling® Bowhunter FAQ' | escape }}
    </h1>
    {%- if section.settings.subheading != blank -%}
      <p class="site-faq__subheading">{{ section.settings.subheading | escape }}</p>
    {%- endif -%}
  </header>

  <nav class="site-faq__nav" aria-label="FAQ categories">
    <a href="#faq-product" class="button button--secondary site-faq__nav-pill">Product</a>
    <a href="#faq-compatibility" class="button button--secondary site-faq__nav-pill">Compatibility</a>
    <a href="#faq-installation" class="button button--secondary site-faq__nav-pill">Installation</a>
    <a href="#faq-field" class="button button--secondary site-faq__nav-pill">In The Field</a>
    <a href="#faq-purchasing" class="button button--secondary site-faq__nav-pill">Purchasing &amp; Shipping</a>
  </nav>

  {% render 'site-faq', section_id: section.id, render_part: 'accordion' %}

  <div class="site-faq__cta color-{{ section.settings.cta_color_scheme }} gradient content-container">
    <h2 class="h1 site-faq__cta-heading">{{ section.settings.cta_heading | escape }}</h2>
    <p class="site-faq__cta-subtext">{{ section.settings.cta_subtext | escape }}</p>
    <div class="site-faq__cta-buttons">
      <a href="{{ bow_product_url }}" class="button button--primary">
        {{ section.settings.cta_primary_label | escape }}
      </a>
      <a href="{{ comparison_page_url }}" class="button button--secondary">
        {{ section.settings.cta_secondary_label | escape }}
      </a>
    </div>
  </div>

  {% render 'site-faq', section_id: section.id, render_part: 'schema' %}
  {% render 'breadcrumb-json-ld' %}
</div>

<script src="{{ 'site-faq.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "FAQ page",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Page heading (H1)",
      "default": "Vsling® Bowhunter FAQ"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Everything you need to know before you buy, install, and hunt with the Vsling®."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Page color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "cta_heading",
      "label": "CTA heading",
      "default": "Ready to make the switch?"
    },
    {
      "type": "text",
      "id": "cta_subtext",
      "label": "CTA subtext",
      "default": "Join bowhunters who've left the floppy sling behind."
    },
    {
      "type": "text",
      "id": "cta_primary_label",
      "label": "CTA primary button",
      "default": "Shop the Vsling® Bow Sling"
    },
    {
      "type": "text",
      "id": "cta_secondary_label",
      "label": "CTA secondary button",
      "default": "See How It Compares"
    },
    {
      "type": "color_scheme",
      "id": "cta_color_scheme",
      "label": "CTA color scheme",
      "default": "scheme-4"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "FAQ page"
    }
  ]
}
{% endschema %}
