{{ 'section-main-page.css' | asset_url | stylesheet_tag }}
{{ 'component-accordion.css' | asset_url | stylesheet_tag }}
{{ 'component-product-faq.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .site-faq__intro {
    margin-bottom: 2.5rem;
  }

  .site-faq__group-title {
    margin: 2.5rem 0 0.5rem;
  }

  .site-faq__group-title:first-of-type {
    margin-top: 0;
  }

  .site-faq__product-link {
    margin: 0 0 1rem;
  }
{%- endstyle -%}

<div class="page-width page-width--narrow section-{{ section.id }}-padding">
  <h1 class="main-page-title page-title h0{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
    {{ page.title | default: section.settings.heading | escape }}
  </h1>

  {%- if section.settings.intro != blank -%}
    <div class="rte site-faq__intro{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      {{ section.settings.intro }}
    </div>
  {%- endif -%}

  {% render 'site-faq', section_id: section.id, render_part: 'accordion' %}
  {% render 'site-faq', section_id: section.id, render_part: 'schema' %}
  {% render 'breadcrumb-json-ld' %}
</div>

{% schema %}
{
  "name": "FAQ page",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Fallback heading",
      "default": "Vsling FAQ for Bowhunters",
      "info": "Used only if the Shopify page title is empty."
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "Introduction",
      "default": "<p>Answers about the Vsling bow sling, crossbow sling, shipping, and support. Shop the <a href=\"/products/bow-sling\">hands-free compound bow sling</a> or the <a href=\"/products/vsling-crossbow-gun-sling\">Vsling crossbow sling</a>, read the <a href=\"/pages/vsling-vs-traditional-bow-sling\">Vsling vs traditional bow sling comparison</a>, or <a href=\"/collections/all\">browse all Vsling products</a>.</p>"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "FAQ page"
    }
  ]
}
{% endschema %}
