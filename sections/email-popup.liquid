{{ 'component-newsletter.css' | asset_url | stylesheet_tag }}

{%- if section.settings.enable_popup or request.design_mode -%}

{%- include 'vsling-handles' -%}

{%- assign bow_product_url = vsling_bow_url -%}

{%- style -%}
  .email-popup {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }

  .email-popup.is-open {
    display: flex;
  }

  .email-popup__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.55);
  }

  .email-popup__dialog {
    position: relative;
    z-index: 1;
    width: min(100%, 48rem);
    background: rgb(var(--color-background));
    color: rgb(var(--color-foreground));
    border-radius: 0.8rem;
    padding: 2.4rem;
    box-shadow: 0 1rem 3rem rgba(0, 0, 0, 0.2);
  }

  .email-popup__close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    border: 0;
    background: transparent;
    cursor: pointer;
    padding: 0.4rem;
    line-height: 0;
  }

  .email-popup__heading {
    margin: 0 0 0.8rem;
  }

  .email-popup__subheading {
    margin: 0 0 1.6rem;
  }

  .email-popup__success-link {
    margin-top: 1.2rem;
    font-weight: 600;
  }
{%- endstyle -%}

<email-popup
  class="email-popup color-{{ section.settings.color_scheme }} gradient"
  data-delay="{{ section.settings.delay_seconds }}"
  data-show-once="{{ section.settings.show_once }}"
  hidden
>
  <div class="email-popup__overlay" data-email-popup-close></div>
  <div
    class="email-popup__dialog"
    role="dialog"
    aria-modal="true"
    aria-labelledby="EmailPopupHeading-{{ section.id }}"
  >
    <button type="button" class="email-popup__close" data-email-popup-close aria-label="Close">
      {{- 'icon-close.svg' | inline_asset_content -}}
    </button>

    <div class="email-popup__form" data-email-popup-form>
      {%- if section.settings.heading != blank -%}
        <h2 id="EmailPopupHeading-{{ section.id }}" class="h2 email-popup__heading">
          {{ section.settings.heading | escape }}
        </h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="email-popup__subheading">{{ section.settings.subheading | escape }}</p>
      {%- endif -%}

      {%- form 'customer', id: 'EmailPopupForm', class: 'newsletter-form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter,popup">
        <div class="newsletter-form__field-wrapper">
          <div class="field">
            <input
              id="EmailPopupEmail"
              type="email"
              name="contact[email]"
              class="field__input"
              value="{{ form.email }}"
              aria-required="true"
              autocorrect="off"
              autocapitalize="off"
              autocomplete="email"
              placeholder="{{ 'newsletter.label' | t }}"
              required
            >
            <label class="field__label" for="EmailPopupEmail">{{ 'newsletter.label' | t }}</label>
            <button
              type="submit"
              class="newsletter-form__button field__button"
              name="commit"
              aria-label="{{ 'newsletter.button_label' | t }}"
            >
              <span class="svg-wrapper">{{- 'icon-arrow.svg' | inline_asset_content -}}</span>
            </button>
          </div>
          {%- if form.errors -%}
            <small class="newsletter-form__message form__message">
              <span class="svg-wrapper">{{- 'icon-error.svg' | inline_asset_content -}}</span>
              {{- form.errors.translated_fields.email | capitalize }}
              {{ form.errors.messages.email -}}
            </small>
          {%- endif -%}
        </div>
      {%- endform -%}
    </div>

    <div class="email-popup__success" data-email-popup-success hidden>
      <h2 class="h2 email-popup__heading">{{ section.settings.success_heading | escape }}</h2>
      <p class="email-popup__subheading">{{ section.settings.success_message | escape }}</p>
      <p class="email-popup__success-link">
        <a href="{{ bow_product_url }}" class="link">
          {{ section.settings.success_link_text | escape }}
        </a>
      </p>
    </div>
  </div>
</email-popup>

<script src="{{ 'email-popup.js' | asset_url }}" defer="defer"></script>

{%- endif -%}

{% schema %}
{
  "name": "Email popup",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_popup",
      "label": "Enable email popup",
      "default": true
    },
    {
      "type": "range",
      "id": "delay_seconds",
      "min": 0,
      "max": 60,
      "step": 1,
      "unit": "s",
      "label": "Delay before popup appears",
      "default": 8
    },
    {
      "type": "checkbox",
      "id": "show_once",
      "label": "Show once per visitor",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Get Vsling hunting tips"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Join our list for new gear drops and bowhunting carry tips."
    },
    {
      "type": "text",
      "id": "success_heading",
      "label": "Success heading",
      "default": "You're in!"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "Thanks for subscribing. Ready to upgrade your carry?"
    },
    {
      "type": "text",
      "id": "success_link_text",
      "label": "Success link text",
      "default": "Shop the Vsling hands-free compound bow sling"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "Email popup"
    }
  ]
}
{% endschema %}
