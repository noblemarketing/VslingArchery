{{ 'component-newsletter.css' | asset_url | stylesheet_tag }}

{%- if section.settings.enable_popup or request.design_mode -%}

{%- include 'vsling-handles' -%}

{%- assign bow_product_url = vsling_bow_url -%}

{%- style -%}
  .email-popup {
    position: fixed;
    right: 1.6rem;
    bottom: 1.6rem;
    left: auto;
    top: auto;
    z-index: 100;
    display: none;
    width: min(calc(100vw - 3.2rem), 34rem);
    pointer-events: none;
  }

  .email-popup.is-open {
    display: block;
  }

  .email-popup__dialog {
    position: relative;
    width: 100%;
    background: rgb(var(--color-background));
    color: rgb(var(--color-foreground));
    border: 0.1rem solid rgba(var(--color-foreground), 0.12);
    border-radius: var(--popup-corner-radius, 0.8rem);
    padding: 1.6rem 3.6rem 1.6rem 1.6rem;
    box-shadow:
      var(--popup-shadow-horizontal-offset, 0) var(--popup-shadow-vertical-offset, 4px)
      var(--popup-shadow-blur-radius, 12px) rgba(0, 0, 0, calc(var(--popup-shadow-opacity, 0.15))),
      0 0.8rem 2.4rem rgba(0, 0, 0, 0.12);
    pointer-events: auto;
  }

  .email-popup__close {
    position: absolute;
    top: 0.8rem;
    right: 0.8rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.8rem;
    height: 2.8rem;
    border: 0.1rem solid rgba(var(--color-foreground), 0.15);
    border-radius: 50%;
    background: rgba(var(--color-foreground), 0.06);
    color: rgb(var(--color-foreground));
    cursor: pointer;
    padding: 0;
    line-height: 1;
    transition: background 0.2s ease, border-color 0.2s ease;
  }

  .email-popup__close:hover,
  .email-popup__close:focus-visible {
    background: rgba(var(--color-foreground), 0.12);
    border-color: rgba(var(--color-foreground), 0.25);
  }

  .email-popup__close-icon {
    font-size: 2rem;
    font-weight: 400;
    line-height: 1;
  }

  .email-popup__heading {
    margin: 0 0 0.6rem;
    font-size: calc(var(--font-heading-scale) * 1.6rem);
    line-height: 1.3;
  }

  .email-popup__subheading {
    margin: 0 0 1.2rem;
    font-size: 1.3rem;
    line-height: 1.45;
  }

  .email-popup__success-link {
    margin-top: 1rem;
    font-size: 1.3rem;
    font-weight: 600;
  }

  @media screen and (max-width: 749px) {
    .email-popup {
      right: 1rem;
      bottom: 1rem;
      width: min(calc(100vw - 2rem), 34rem);
    }

    .email-popup__dialog {
      padding: 1.4rem 3.4rem 1.4rem 1.4rem;
    }
  }
{%- endstyle -%}

<email-popup
  class="email-popup color-{{ section.settings.color_scheme }} gradient"
  data-delay="{{ section.settings.delay_seconds }}"
  data-show-once="{{ section.settings.show_once }}"
  hidden
>
  <div
    class="email-popup__dialog"
    role="dialog"
    aria-modal="false"
    aria-labelledby="EmailPopupHeading-{{ section.id }}"
  >
    <button type="button" class="email-popup__close" data-email-popup-close aria-label="Close newsletter signup">
      <span class="email-popup__close-icon" aria-hidden="true">&times;</span>
    </button>

    <div class="email-popup__form" data-email-popup-form>
      {%- if section.settings.heading != blank -%}
        <h2 id="EmailPopupHeading-{{ section.id }}" class="email-popup__heading">
          {{ section.settings.heading | escape }}
        </h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="email-popup__subheading">{{ section.settings.subheading | escape }}</p>
      {%- endif -%}

      {%- form 'customer', id: 'EmailPopupForm', class: 'newsletter-form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter,popup">
        <div class="newsletter-form__field-wrapper">
          <div class="field">
            <input
              id="EmailPopupEmail"
              type="email"
              name="contact[email]"
              class="field__input"
              value="{{ form.email }}"
              aria-required="true"
              autocorrect="off"
              autocapitalize="off"
              autocomplete="email"
              placeholder="{{ 'newsletter.label' | t }}"
              required
            >
            <label class="field__label" for="EmailPopupEmail">{{ 'newsletter.label' | t }}</label>
            <button
              type="submit"
              class="newsletter-form__button field__button"
              name="commit"
              aria-label="{{ 'newsletter.button_label' | t }}"
            >
              <span class="svg-wrapper">{{- 'icon-arrow.svg' | inline_asset_content -}}</span>
            </button>
          </div>
          {%- if form.errors -%}
            <small class="newsletter-form__message form__message">
              <span class="svg-wrapper">{{- 'icon-error.svg' | inline_asset_content -}}</span>
              {{- form.errors.translated_fields.email | capitalize }}
              {{ form.errors.messages.email -}}
            </small>
          {%- endif -%}
        </div>
      {%- endform -%}
    </div>

    <div class="email-popup__success" data-email-popup-success hidden>
      <h2 class="email-popup__heading">{{ section.settings.success_heading | escape }}</h2>
      <p class="email-popup__subheading">{{ section.settings.success_message | escape }}</p>
      <p class="email-popup__success-link">
        <a href="{{ bow_product_url }}" class="link">
          {{ section.settings.success_link_text | escape }}
        </a>
      </p>
    </div>
  </div>
</email-popup>

<script src="{{ 'email-popup.js' | asset_url }}" defer="defer"></script>

{%- endif -%}

{% schema %}
{
  "name": "Email popup",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_popup",
      "label": "Enable email popup",
      "default": true
    },
    {
      "type": "range",
      "id": "delay_seconds",
      "min": 0,
      "max": 60,
      "step": 1,
      "unit": "s",
      "label": "Delay before popup appears",
      "default": 8
    },
    {
      "type": "checkbox",
      "id": "show_once",
      "label": "Show once per visitor",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Get Vsling hunting tips"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Join our list for new gear drops and bowhunting carry tips."
    },
    {
      "type": "text",
      "id": "success_heading",
      "label": "Success heading",
      "default": "You're in!"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "Thanks for subscribing. Ready to upgrade your carry?"
    },
    {
      "type": "text",
      "id": "success_link_text",
      "label": "Success link text",
      "default": "Shop the Vsling hands-free compound bow sling"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "Email popup"
    }
  ]
}
{% endschema %}
