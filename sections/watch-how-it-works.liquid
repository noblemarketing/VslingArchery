{%- liquid
  assign hero_alt = section.settings.image_alt
  if section.settings.image != blank
    assign background_image = section.settings.image | image_url: width: 3840
  else
    assign background_image = 'watch-how-it-works-bg.png' | asset_url
  endif
-%}

{%- style -%}
  #WatchHowItWorks-{{ section.id }} {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 34rem;
    overflow: hidden;
    width: 100%;
  }

  @media screen and (min-width: 750px) {
    #WatchHowItWorks-{{ section.id }} {
      min-height: 56rem;
    }
  }

  #WatchHowItWorks-{{ section.id }} .watch-how-it-works__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    background-image: url('{{ background_image }}');
    background-size: cover;
    background-position: center center;
    background-repeat: no-repeat;
  }

  #WatchHowItWorks-{{ section.id }}::after {
    content: '';
    position: absolute;
    inset: 0;
    background: #000;
    opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    z-index: 1;
    pointer-events: none;
  }

  #WatchHowItWorks-{{ section.id }} .watch-how-it-works__content {
    position: relative;
    z-index: 2;
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
    padding: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px 2rem {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    #WatchHowItWorks-{{ section.id }} .watch-how-it-works__content {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div
  id="WatchHowItWorks-{{ section.id }}"
  class="watch-how-it-works{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}"
  role="img"
  aria-label="{{ hero_alt | escape }}"
>
  <div class="watch-how-it-works__bg" aria-hidden="true"></div>

  <div class="watch-how-it-works__content">
    {%- if section.settings.button_label != blank -%}
      <a
        {% if section.settings.button_link == blank %}
          role="link" aria-disabled="true"
        {% else %}
          href="{{ section.settings.button_link }}"
        {% endif %}
        class="button{% if section.settings.button_style_secondary %} button--secondary{% else %} button--primary{% endif %}"
      >
        {{ section.settings.button_label | escape }}
      </a>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Watch how it works",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image",
      "info": "Leave blank to use the default hunting gear photo."
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image alt text",
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "label": "Image overlay",
      "default": 20
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "WATCH HOW IT WORKS"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "checkbox",
      "id": "button_style_secondary",
      "label": "Use secondary button style",
      "default": false
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Watch how it works",
      "settings": {
        "button_label": "WATCH HOW IT WORKS"
      }
    }
  ]
}
{% endschema %}
