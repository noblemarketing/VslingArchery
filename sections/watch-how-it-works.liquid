{{ 'section-image-banner.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign hero_alt = section.settings.image_alt | default: 'Bowhunter using Vsling bow sling in the field'
-%}

{%- style -%}
  #WatchHowItWorks-{{ section.id }} {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 34rem;
    overflow: hidden;
  }

  @media screen and (min-width: 750px) {
    #WatchHowItWorks-{{ section.id }} {
      min-height: 56rem;
    }
  }

  #WatchHowItWorks-{{ section.id }} .watch-how-it-works__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  #WatchHowItWorks-{{ section.id }} .watch-how-it-works__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #WatchHowItWorks-{{ section.id }}::after {
    content: '';
    position: absolute;
    inset: 0;
    background: #000;
    opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    z-index: 1;
    pointer-events: none;
  }

  #WatchHowItWorks-{{ section.id }} .watch-how-it-works__content {
    position: relative;
    z-index: 2;
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
    padding: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px 2rem {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    #WatchHowItWorks-{{ section.id }} .watch-how-it-works__content {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div
  id="WatchHowItWorks-{{ section.id }}"
  class="watch-how-it-works{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}"
>
  <div class="watch-how-it-works__media media">
    {%- if section.settings.image != blank -%}
      {{
        section.settings.image
        | image_url: width: 3840
        | image_tag:
          width: section.settings.image.width,
          height: section.settings.image.width | divided_by: section.settings.image.aspect_ratio,
          sizes: '100vw',
          widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840',
          alt: hero_alt,
          fetchpriority: 'auto',
          class: 'watch-how-it-works__image'
      }}
    {%- else -%}
      <img
        src="{{ 'watch-how-it-works-bg.jpg' | asset_url }}"
        alt="{{ hero_alt | escape }}"
        width="2000"
        height="1333"
        loading="lazy"
        class="watch-how-it-works__image"
      >
    {%- endif -%}
  </div>

  <div class="watch-how-it-works__content">
    {%- if section.settings.button_label != blank -%}
      <a
        {% if section.settings.button_link == blank %}
          role="link" aria-disabled="true"
        {% else %}
          href="{{ section.settings.button_link }}"
        {% endif %}
        class="button{% if section.settings.button_style_secondary %} button--secondary{% else %} button--primary{% endif %}"
      >
        {{ section.settings.button_label | escape }}
      </a>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Watch how it works",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image alt text",
      "default": "Bowhunter using Vsling bow sling in the field"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "label": "Image overlay",
      "default": 15
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "WATCH HOW IT WORKS"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "checkbox",
      "id": "button_style_secondary",
      "label": "Use secondary button style",
      "default": false
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Watch how it works",
      "settings": {
        "button_label": "WATCH HOW IT WORKS"
      }
    }
  ]
}
{% endschema %}
