{{ 'section-main-page.css' | asset_url | stylesheet_tag }}

{%- include 'vsling-handles' -%}

{%- liquid
  assign bow_product_url = vsling_bow_url
  assign crossbow_product_url = vsling_crossbow_url
  assign faq_url = vsling_faq_url
-%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .comparison__intro {
    margin-bottom: 2rem;
  }

  .comparison__table-wrapper {
    overflow-x: auto;
    margin: 2rem 0;
  }

  .comparison__table {
    width: 100%;
    border-collapse: collapse;
    font-size: 1.5rem;
  }

  .comparison__table th,
  .comparison__table td {
    border: 0.1rem solid rgba(var(--color-foreground), 0.15);
    padding: 1.2rem 1.4rem;
    text-align: left;
    vertical-align: top;
  }

  .comparison__table th {
    background: rgba(var(--color-foreground), 0.05);
    font-weight: 700;
  }

  .comparison__cta {
    margin-top: 2.5rem;
  }
{%- endstyle -%}

<div class="page-width page-width--narrow section-{{ section.id }}-padding">
  <h1 class="main-page-title page-title h0">
    {{ page.title | default: section.settings.heading | escape }}
  </h1>

  <div class="rte comparison__intro">
    {%- if section.settings.intro != blank -%}
      {{ section.settings.intro }}
    {%- else -%}
      <p>
        Choosing between a traditional bow sling and the Vsling comes down to one question: do you want to remove your sling before every shot?
        The Vsling is a shoot-ready, hands-free elastic bow sling built for compound bow hunters who need quiet carry and instant draw readiness in the stand or on the ground.
      </p>
    {%- endif -%}
  </div>

  <div class="comparison__table-wrapper">
    <table class="comparison__table">
      <thead>
        <tr>
          <th scope="col">Feature</th>
          <th scope="col">Traditional bow sling</th>
          <th scope="col">Vsling elastic bow sling</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <th scope="row">Shoot with sling on</th>
          <td>Usually removed or unclipped before drawing</td>
          <td>Draw and shoot without removing — always ready</td>
        </tr>
        <tr>
          <th scope="row">Carry style</th>
          <td>Loose strap that dangles and flaps</td>
          <td>Elastic tension keeps bow snug and quiet on your body</td>
        </tr>
        <tr>
          <th scope="row">Hands-free movement</th>
          <td>Limited — bow swings when you climb or glass</td>
          <td>Hands free for treestands, ladders, and glassing</td>
        </tr>
        <tr>
          <th scope="row">Noise in the field</th>
          <td>Strap slap on brush and gear</td>
          <td>Silent elastic carry — no dangling hardware</td>
        </tr>
        <tr>
          <th scope="row">Installation</th>
          <td>Buckles, clips, or extra hardware</td>
          <td>Universal fit with a simple double-knot adjustment</td>
        </tr>
        <tr>
          <th scope="row">Treestand hunting</th>
          <td>Bow hangs loose; extra handling before the shot</td>
          <td>Bow stays tight in the stand — draw-ready when game appears</td>
        </tr>
        <tr>
          <th scope="row">Crossbow option</th>
          <td>Separate strap systems for crossbows</td>
          <td>Same Vsling system available for <a href="{{ crossbow_product_url }}">crossbow and treestand hunting</a></td>
        </tr>
      </tbody>
    </table>
  </div>

  <div class="rte">
    <h2>Why hunters upgrade to Vsling</h2>
    <p>
      A traditional bow sling was designed for carry, not for the shot. That means fumbling with clips, sliding a strap off your shoulder,
      or letting your bow swing while you climb — all noise and movement you do not want when a buck is close.
    </p>
    <p>
      The Vsling uses 100% elastic to hold your compound bow comfortably against your body. You move hands-free through cover,
      sit quietly in a treestand, and transition to full draw in seconds without removing the sling.
      It is the same shoot-ready philosophy behind the <a href="{{ bow_product_url }}">Vsling hands-free compound bow sling</a>
      and the <a href="{{ crossbow_product_url }}">Vsling crossbow sling</a>.
    </p>

    <h2>Which sling is right for you?</h2>
    <p>
      If you only need basic shoulder carry and always remove your sling before shooting, a traditional strap may be enough.
      If you hunt from treestands, hike rough terrain, or want your bow tight and quiet until the moment of truth, the Vsling is built for that hunt.
    </p>
    <p>
      Still deciding? Read <a href="{{ faq_url }}">common questions about the Vsling</a> or shop the
      <a href="{{ bow_product_url }}">shoot-ready Vsling bow sling</a> built for Mathews, Hoyt, Bear, and other modern compounds.
    </p>
  </div>

  <div class="comparison__cta">
    <a href="{{ bow_product_url }}" class="button button--primary">
      {{ section.settings.cta_label | default: 'Shop the Vsling Bow Sling' | escape }}
    </a>
  </div>

  {% render 'breadcrumb-json-ld' %}
</div>

{% schema %}
{
  "name": "Vsling comparison page",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Fallback heading",
      "default": "Vsling vs Traditional Bow Sling"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "Introduction",
      "default": "<p>Choosing between a traditional bow sling and the Vsling comes down to one question: do you want to remove your sling before every shot? The Vsling is a shoot-ready, hands-free elastic bow sling built for compound bow hunters who need quiet carry and instant draw readiness in the stand or on the ground.</p>"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA button label",
      "default": "Shop the Vsling Bow Sling"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Vsling comparison page"
    }
  ]
}
{% endschema %}
