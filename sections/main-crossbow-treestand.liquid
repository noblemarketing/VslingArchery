{{ 'section-image-banner.css' | asset_url | stylesheet_tag }}
{{ 'section-main-page.css' | asset_url | stylesheet_tag }}
{{ 'component-accordion.css' | asset_url | stylesheet_tag }}
{{ 'component-site-faq.css' | asset_url | stylesheet_tag }}
{{ 'component-crossbow-treestand.css' | asset_url | stylesheet_tag }}

{%- include 'vsling-handles' -%}
{%- include 'product-crossbow-data' -%}

{%- liquid
  assign hero_image = section.settings.hero_image
  assign hero_alt = section.settings.hero_image_alt | default: 'Hunter climbing a treestand with Vsling crossbow sling for hands-free treestand hunting'
  assign crossbow_product_url = vsling_crossbow_url
  assign bow_product_url = vsling_bow_url
  assign bino_product_url = vsling_bino_url
  assign faq_page_url = vsling_faq_url
  assign comparison_page_url = vsling_comparison_url
-%}

{%- style -%}
  #CrossbowTreestandHero-{{ section.id }}::after {
    opacity: {{ section.settings.hero_overlay_opacity | divided_by: 100.0 }};
  }

  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div
  id="CrossbowTreestandHero-{{ section.id }}"
  class="crossbow-treestand__hero banner banner--content-align-center banner--content-align-mobile-center banner--medium{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}"
>
  <div class="banner__media media{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
    {%- if hero_image != blank -%}
      {{
        hero_image
        | image_url: width: 3840
        | image_tag:
          width: hero_image.width,
          height: hero_image.width | divided_by: hero_image.aspect_ratio,
          sizes: '100vw',
          widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840',
          alt: hero_alt,
          fetchpriority: 'high'
      }}
    {%- else -%}
      <img
        src="{{ 'comparison-hero-hunter-turkey.png' | asset_url }}"
        alt="{{ hero_alt | escape }}"
        width="2000"
        height="1333"
        loading="eager"
        fetchpriority="high"
        sizes="100vw"
        class="crossbow-treestand__hero-image"
      >
    {%- endif -%}
  </div>

  <div class="banner__content banner__content--middle-center page-width{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
    <div class="banner__box content-container content-container--full-width-mobile color-{{ section.settings.hero_color_scheme }} gradient">
      <h1 class="banner__heading inline-richtext h0" id="CrossbowTreestandHeading">
        {{ section.settings.heading | default: 'Vsling Crossbow Sling for Treestand Hunting' | escape }}
      </h1>
      <div class="banner__text rte">
        <p id="CrossbowTreestandLead">
          {{ section.settings.hero_text | default: 'Hands-free climb. Silent carry. Shoot with the sling on — the always-ready crossbow sling built for treestand hunters.' | escape }}
        </p>
      </div>
      <div class="banner__buttons">
        <a href="{{ crossbow_product_url }}" class="button button--primary">Shop the Vsling™ Crossbow Sling</a>
      </div>
    </div>
  </div>
</div>

<div class="page-width page-width--narrow section-{{ section.id }}-padding color-{{ section.settings.color_scheme }} gradient">
  <div class="rte">
    <h2>The Treestand Hunter's Crossbow Carry Problem</h2>
    <p>
      Treestand hunting demands both hands on the ladder, a quiet climb, and a crossbow that stays secure from ground to seat.
      Traditional crossbow slings dangle, bounce, and usually come off before you shoot — extra movement and noise when a deer steps in at close range.
    </p>
    <p>
      {{ crossbow_aio_sentence }}
      If you are searching for the best crossbow sling for treestand hunting, the Vsling™ is the shoot-with-it-on system built for exactly that hunt.
    </p>

    <h2>Climb. Wait. Shoot. — Three Phases, One Sling</h2>
    <ul class="crossbow-treestand__phase-grid" role="list">
      <li class="crossbow-treestand__phase-card">
        <h3 class="h4">Climb</h3>
        <p>100% elastic tension keeps your crossbow tight to your body. Both hands stay on the ladder. No strap slapping the stand or climbing sticks.</p>
      </li>
      <li class="crossbow-treestand__phase-card">
        <h3 class="h4">Wait</h3>
        <p>Your crossbow stays snug and silent while you settle in. No swinging weight. No repositioning a loose sling when game is close.</p>
      </li>
      <li class="crossbow-treestand__phase-card">
        <h3 class="h4">Shoot</h3>
        <p>The Vsling™ stays on for the shot. Transition from carry to full draw in seconds — no removal, no fumbling, no wasted movement.</p>
      </li>
    </ul>

    <h2>Vsling™ vs Traditional Crossbow Slings</h2>
    <div class="crossbow-treestand__table-wrapper">
      <table class="crossbow-treestand__table">
        <thead>
          <tr>
            <th scope="col">Feature</th>
            <th scope="col" class="crossbow-treestand__col-vsling">Vsling™</th>
            <th scope="col">Traditional Sling</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <th scope="row">Hands-free treestand climb</th>
            <td class="crossbow-treestand__col-vsling">Yes</td>
            <td>Often loose / noisy</td>
          </tr>
          <tr>
            <th scope="row">Stays on for the shot</th>
            <td class="crossbow-treestand__col-vsling">Yes</td>
            <td>Usually removed first</td>
          </tr>
          <tr>
            <th scope="row">Silent elastic carry</th>
            <td class="crossbow-treestand__col-vsling">Yes</td>
            <td>Straps flap and bounce</td>
          </tr>
          <tr>
            <th scope="row">Treestand descent</th>
            <td class="crossbow-treestand__col-vsling">Secure on the way down</td>
            <td>Often repositioned</td>
          </tr>
          <tr>
            <th scope="row">Made in USA</th>
            <td class="crossbow-treestand__col-vsling">Hector, Minnesota</td>
            <td>Varies</td>
          </tr>
        </tbody>
      </table>
    </div>

    <h2>How to Install on Your Crossbow</h2>
    <ol>
      <li>Attach the two included key rings to your crossbow front and rear sling attachment points.</li>
      <li>Loop the sling through the rear ring, run it forward through the front ring, return to the rear, and tie a snug double knot.</li>
      <li>Adjust tension until the crossbow rides tight and quiet against your body. Re-snug the knot and you are ready to hunt.</li>
    </ol>
    <p>
      No tools required. Installation takes under two minutes.
      Compound bow hunters in your group can run the same system with the <a href="{{ bow_product_url }}">Vsling® Bow Sling</a>.
      Glass hands-free from the stand with the <a href="{{ bino_product_url }}">Vsling™ Bino Sling</a>.
      Read the full <a href="{{ comparison_page_url }}">Vsling vs Traditional Bow Sling</a> comparison or browse the <a href="{{ faq_page_url }}">Bowhunter FAQ</a>.
    </p>

    <h2>Treestand Crossbow Sling FAQ</h2>
    {% render 'crossbow-treestand-faq', section_id: section.id, render_part: 'accordion' %}
  </div>

  <div class="crossbow-treestand__cta color-{{ section.settings.cta_color_scheme }} gradient content-container">
    <h2 class="h1">{{ section.settings.cta_heading | default: 'Ready for your next treestand hunt?' | escape }}</h2>
    <p class="rte">{{ section.settings.cta_subtext | default: 'The Vsling™ Crossbow/Gun Sling keeps your weapon hands-free, silent, and shoot-ready from the climb to the shot. Complete your setup with the Vsling™ Bino Sling for hands-free glassing.' | escape }}</p>
    <div class="crossbow-treestand__cta-buttons">
      <a href="{{ crossbow_product_url }}" class="button button--primary">
        {{ section.settings.cta_primary_label | default: 'Shop the Vsling™ Crossbow Sling' | escape }}
      </a>
      <a href="{{ faq_page_url }}" class="button button--secondary">
        {{ section.settings.cta_secondary_label | default: 'Read the Bowhunter FAQ' | escape }}
      </a>
    </div>
  </div>

  {% render 'crossbow-treestand-faq', section_id: section.id, render_part: 'schema' %}
  {% render 'breadcrumb-json-ld' %}

  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebPage",
      "name": {{ section.settings.heading | default: 'Vsling Crossbow Sling for Treestand Hunting' | json }},
      "description": {{ section.settings.hero_text | default: 'Hands-free climb. Silent carry. Shoot with the sling on — the always-ready crossbow sling built for treestand hunters.' | json }},
      "speakable": {
        "@type": "SpeakableSpecification",
        "cssSelector": ["#CrossbowTreestandHeading", "#CrossbowTreestandLead", "#CrossbowTreestandFirstAnswer"]
      }
    }
  </script>
</div>

<script src="{{ 'site-faq.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "Crossbow treestand page",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image",
      "info": "Leave blank to use the default bundled hero photo."
    },
    {
      "type": "text",
      "id": "hero_image_alt",
      "label": "Hero image alt text",
      "default": "Hunter climbing a treestand with Vsling crossbow sling for hands-free treestand hunting"
    },
    {
      "type": "range",
      "id": "hero_overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "%",
      "label": "Hero image overlay",
      "default": 30
    },
    {
      "type": "color_scheme",
      "id": "hero_color_scheme",
      "label": "Hero text box color scheme",
      "default": "scheme-3"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Page heading (H1)",
      "default": "Vsling Crossbow Sling for Treestand Hunting"
    },
    {
      "type": "text",
      "id": "hero_text",
      "label": "Hero subtext",
      "default": "Hands-free climb. Silent carry. Shoot with the sling on — the always-ready crossbow sling built for treestand hunters."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Content color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "cta_heading",
      "label": "CTA heading",
      "default": "Ready for your next treestand hunt?"
    },
    {
      "type": "text",
      "id": "cta_subtext",
      "label": "CTA subtext",
      "default": "The Vsling™ Crossbow/Gun Sling keeps your weapon hands-free, silent, and shoot-ready from the climb to the shot."
    },
    {
      "type": "text",
      "id": "cta_primary_label",
      "label": "CTA primary button",
      "default": "Shop the Vsling™ Crossbow Sling"
    },
    {
      "type": "text",
      "id": "cta_secondary_label",
      "label": "CTA secondary button",
      "default": "Read the Bowhunter FAQ"
    },
    {
      "type": "color_scheme",
      "id": "cta_color_scheme",
      "label": "CTA color scheme",
      "default": "scheme-4"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Content padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Content padding bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Crossbow treestand page"
    }
  ]
}
{% endschema %}
