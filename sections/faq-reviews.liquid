{{ 'component-faq-reviews.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding">
    <header class="faq-reviews__header">
      <h2 class="h0">{{ section.settings.heading | escape }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="faq-reviews__subheading">{{ section.settings.subheading | escape }}</p>
      {%- endif -%}
    </header>

    <ul class="faq-reviews__grid{% if section.blocks.size >= 3 %} faq-reviews__grid--3-col{% endif %}" role="list">
      {%- for block in section.blocks -%}
        <li {{ block.shopify_attributes }}>
          <article class="faq-reviews__card">
            <div class="faq-reviews__stars" aria-label="{{ block.settings.rating }} out of 5 stars">
              {%- for i in (1..5) -%}
                {%- if i <= block.settings.rating -%}★{%- else -%}☆{%- endif -%}
              {%- endfor -%}
            </div>
            <blockquote class="faq-reviews__quote">
              <p>&ldquo;{{ block.settings.quote | escape }}&rdquo;</p>
            </blockquote>
            <p class="faq-reviews__author">{{ block.settings.author | escape }}</p>
            {%- if block.settings.detail != blank -%}
              <p class="faq-reviews__detail">{{ block.settings.detail | escape }}</p>
            {%- endif -%}
          </article>
        </li>
      {%- endfor -%}
    </ul>
  </div>
</div>

{%- if section.blocks.size > 0 -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Product",
      "name": "Vsling® Bow Sling",
      "brand": { "@type": "Brand", "name": "Vsling Archery" },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "5",
        "reviewCount": {{ section.blocks.size | json }}
      },
      "review": [
        {%- for block in section.blocks -%}
          {
            "@type": "Review",
            "reviewRating": {
              "@type": "Rating",
              "ratingValue": {{ block.settings.rating | json }},
              "bestRating": "5"
            },
            "author": { "@type": "Person", "name": {{ block.settings.author | json }} },
            "reviewBody": {{ block.settings.quote | json }}
          }{%- unless forloop.last -%},{%- endunless -%}
        {%- endfor -%}
      ]
    }
  </script>
{%- endif -%}

{% schema %}
{
  "name": "FAQ reviews",
  "tag": "section",
  "class": "section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What Bowhunters Are Saying"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Real feedback from hunters who made the switch to Vsling®."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 52
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 52
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "label": "Review quote",
          "default": "Best sling I have ever run. I draw and shoot without taking it off."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author name",
          "default": "Verified Buyer"
        },
        {
          "type": "text",
          "id": "detail",
          "label": "Author detail",
          "default": "Compound bow hunter"
        },
        {
          "type": "range",
          "id": "rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "label": "Star rating",
          "default": 5
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ reviews",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "quote": "Over this last week I've had the pleasure of using one heck of a comfortable, easy to use bow sling. They are hand made here in south central Minnesota even! This thing makes it super easy to sling your bow, it's comfortable to wear, and it stows very nicely on the outside of your bow while you shoot. Head on over to VSling Archery and get yourself an amazing addition to your bow! You'll be going from slinging your bow, to slinging arrows in no time!",
            "author": "The Archer's Corner",
            "detail": "",
            "rating": 5
          }
        },
        {
          "type": "review",
          "settings": {
            "quote": "It's super quiet, it's light, it's super easy and its effective.",
            "author": "Jay Gregory",
            "detail": "",
            "rating": 5
          }
        },
        {
          "type": "review",
          "settings": {
            "quote": "Love my Vsling bow sling! It's fantastic for keeping my hands free during the ride in on my bike and while climbing up to my treestand. The design is quiet, secure, and allows quick access without ever needing to remove it",
            "author": "Markis Dettman",
            "detail": "",
            "rating": 5
          }
        },
        {
          "type": "review",
          "settings": {
            "quote": "I've tried many bow/gun slings. Vsling is by far the most quiet, easiest and most comfortable sling on the market! I also run the bino Vsling and love it!",
            "author": "Spenser Glaeser",
            "detail": "",
            "rating": 5
          }
        }
      ]
    }
  ]
}
{% endschema %}
