{%- comment -%}
  FAQ accordion and FAQPage JSON-LD for Vsling Bow Sling and Crossbow/Gun Sling pages.

  Usage:
    {% render 'product-faq', section_id: section.id, render_part: 'accordion' %}
    {% render 'product-faq', section_id: section.id, render_part: 'schema' %}
{%- endcomment -%}

{%- liquid
  assign vsling_bow_handle = 'bow-sling'
  assign vsling_crossbow_handle = 'vsling-crossbow-gun-sling'

  assign product_handle_downcase = product.handle | downcase
  assign product_title_downcase = product.title | downcase
  assign is_bow_sling_product = false
  assign is_crossbow_product = false

  if product.handle == vsling_crossbow_handle or product.handle == 'untitled-mar22_12-23' or product_handle_downcase contains 'crossbow' or product_handle_downcase contains 'gun-sling' or product_title_downcase contains 'crossbow' or product_title_downcase contains 'gun sling'
    assign is_crossbow_product = true
  elsif product.handle == vsling_bow_handle or product_handle_downcase contains 'bow-sling' or product_title_downcase contains 'bow sling'
    unless product_handle_downcase contains 'bino' or product_title_downcase contains 'bino'
      assign is_bow_sling_product = true
    endunless
  endif
-%}

{%- if is_bow_sling_product or is_crossbow_product -%}
  {%- if is_crossbow_product -%}
    {%- liquid
      assign crossbow_faq_q1 = 'Does the Vsling® Crossbow Sling stay on during the shot?'
      assign crossbow_faq_a1 = 'Yes. The Vsling® is engineered to stay on your crossbow or firearm during the shot. No removal needed, no repositioning, no wasted movement. It transfers from carry mode to shoot mode in seconds.'

      assign crossbow_faq_q2 = 'What crossbows and firearms is the Vsling® compatible with?'
      assign crossbow_faq_a2 = 'The Vsling® Crossbow/Gun Edition fits any crossbow or firearm with standard sling attachment points. Each sling ships with two loose key rings so you can install it to match your exact setup.'

      assign crossbow_faq_q3 = 'How do I install the Vsling® on a crossbow?'
      assign crossbow_faq_a3 = "Attach the two included key rings to your front and rear sling attachment points. Loop the sling through the rear ring, run it forward through the front ring, return to the rear, and tie a snug double knot. Adjust tension and you're ready. Full installation video at @VslingArchery on YouTube."

      assign crossbow_faq_q4 = 'Is the Vsling® good for treestand hunting?'
      assign crossbow_faq_a4 = 'Yes — treestand hunting is one of the primary use cases. The 100% elastic design keeps your crossbow snug and silent during the climb with both hands free. When a deer steps in, the sling stays on for the shot — no fumbling, no noise. Pair it with the Vsling Bino Sling for hands-free glassing from the stand.'

      assign crossbow_faq_q5 = 'What is the Vsling® Crossbow/Gun Sling made of?'
      assign crossbow_faq_a5 = '100% elastic material — the same construction as the original Vsling® Bow Sling, tuned for crossbow and firearm carry. Made in Hector, Minnesota, USA.'

      assign faq_questions = crossbow_faq_q1 | append: '~~~' | append: crossbow_faq_q2 | append: '~~~' | append: crossbow_faq_q3 | append: '~~~' | append: crossbow_faq_q4 | append: '~~~' | append: crossbow_faq_q5 | split: '~~~'
      assign faq_answers = crossbow_faq_a1 | append: '~~~' | append: crossbow_faq_a2 | append: '~~~' | append: crossbow_faq_a3 | append: '~~~' | append: crossbow_faq_a4 | append: '~~~' | append: crossbow_faq_a5 | split: '~~~'
    -%}
  {%- else -%}
  {%- liquid
    if is_bow_sling_product
      assign faq_q1 = 'Will this get in the way when I draw?'
      assign faq_a1 = 'No — the Vsling stays tight to your bow and out of your string path. You can draw and shoot with it on from a stand, the ground, or uphill and downhill.'

      assign faq_q2 = 'Do I have to take it off before I shoot?'
      assign faq_a2 = 'No. You shoot with the Vsling on — no unclipping, no sliding it off, no last-second fumble. The elastic stays clear when you draw.'

      assign faq_q3 = 'How does the Vsling compare to a traditional bow sling?'
      assign faq_a3 = 'A traditional sling dangles, flaps, and usually comes off before you shoot. The Vsling is elastic, stays quiet on your body, and you draw and shoot without removing it.'

      assign faq_q4 = 'What compound bows has the Vsling been tested on?'
      assign faq_a4 = 'All modern compound bows! The Vsling has been tested on Mathews V3 31, Mathews Phase 4, Mathews ARC, Hoyt RX-7 Ultra, Hoyt Ventum Pro 33, Elite EnKore, Elite Remedy, Prime Nexus 2, Prime Inline 5, Bear Refine EKO, Bear Alaskan XT, PSE Fortis, PSE Sicario, Bowtech Revolt X, and Darton Spectra E.'

      assign faq_q5 = 'How do I put the Vsling on my bow?'
      assign faq_a5 = 'Attach it to your bow, adjust the elastic to your body, and lock it in with a snug double knot. Takes a few minutes and you fine-tune it once.'

      assign faq_q6 = 'Is the Vsling good for treestand hunting?'
      assign faq_a6 = 'Yes. The Vsling keeps your bow tight while you climb and sit in the stand. Your hands stay free and you are draw-ready when a deer steps out. Pair it with the Vsling Bino Sling for the same hands-free carry on your binoculars.'

      assign faq_q7 = 'How tough is the Vsling?'
      assign faq_a7 = 'The Vsling is built from durable elastic made for hard hunting use. Machine wash it and air dry. Check it before each season like any gear you trust your hunt to.'

      assign faq_q8 = 'Does the Vsling have a warranty?'
      assign faq_a8 = 'Yes — every Vsling comes with a 1-year warranty. Email sam@vslingarchery.com if anything is not right and we will take care of it.'

      assign faq_questions = faq_q1 | append: '|||' | append: faq_q2 | append: '|||' | append: faq_q3 | append: '|||' | append: faq_q4 | append: '|||' | append: faq_q5 | append: '|||' | append: faq_q6 | append: '|||' | append: faq_q7 | append: '|||' | append: faq_q8 | split: '|||'
      assign faq_answers = faq_a1 | append: '|||' | append: faq_a2 | append: '|||' | append: faq_a3 | append: '|||' | append: faq_a4 | append: '|||' | append: faq_a5 | append: '|||' | append: faq_a6 | append: '|||' | append: faq_a7 | append: '|||' | append: faq_a8 | split: '|||'
    endif
  -%}
  {%- endif -%}

  {%- if render_part == 'accordion' -%}
    <div class="product-faq quick-add-hidden">
      <h2 class="h3 product-faq__heading">Frequently Asked Questions</h2>
      {%- for question in faq_questions -%}
        {%- assign answer = faq_answers[forloop.index0] -%}
        <div class="product__accordion accordion">
          <details id="Details-FAQ-{{ forloop.index }}-{{ section_id }}">
            <summary id="Summary-FAQ-{{ forloop.index }}-{{ section_id }}">
              <div class="summary__title">
                {% render 'icon-accordion', icon: 'question_mark' %}
                <h3 class="h4 accordion__title inline-richtext">
                  {{ question | escape }}
                </h3>
              </div>
              {{- 'icon-caret.svg' | inline_asset_content -}}
            </summary>
            <div
              class="accordion__content rte"
              id="FAQAccordion-{{ forloop.index }}-{{ section_id }}"
              role="region"
              aria-labelledby="Summary-FAQ-{{ forloop.index }}-{{ section_id }}"
            >
              <p>{{ answer | escape }}</p>
            </div>
          </details>
        </div>
      {%- endfor -%}
      {% render 'product-seo-links' %}
    </div>
  {%- endif -%}

  {%- if render_part == 'schema' -%}
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
          {%- for question in faq_questions -%}
          {
            "@type": "Question",
            "name": {{ question | json }},
            "acceptedAnswer": {
              "@type": "Answer",
              "text": {{ faq_answers[forloop.index0] | json }}
            }
          }{%- unless forloop.last -%},{%- endunless -%}
          {%- endfor -%}
        ]
      }
    </script>
  {%- endif -%}
{%- endif -%}
