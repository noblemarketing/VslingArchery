{%- comment -%}
  Sets page-level SEO variables for title, meta description, Open Graph, and Twitter cards.
  Included from layout/theme.liquid (shared template scope).

  Titles: one primary keyword, naturally placed. Differentiators: Shoot-Ready, Hands-Free.
  Descriptions: one complete standalone sentence — readable aloud, AI-quotable.
{%- endcomment -%}

{%- liquid
  assign seo_page_title = blank
  assign seo_meta_description = blank
  assign seo_meta_keywords = blank
  assign seo_og_title = blank
  assign seo_og_description = blank
  assign seo_twitter_title = blank
  assign seo_twitter_description = blank
  assign product_schema_description = blank
  assign current_year = 'now' | date: '%Y'

  if request.page_type == 'index'
    assign seo_page_title = 'Vsling Shoot-Ready Bow Sling — Hands-Free ' | append: current_year
    assign seo_meta_description = 'The Vsling keeps your compound bow hands-free and shoot-ready, so you draw and shoot without ever removing your sling.'
    assign seo_og_title = 'Vsling — Shoot Without Removing Your Sling'
    assign seo_og_description = 'The Vsling is a patented elastic bow sling that keeps your bow quiet, secure, and ready to shoot from the moment game steps in.'
    assign seo_twitter_title = seo_og_title
    assign seo_twitter_description = seo_og_description

  elsif request.page_type == 'product'
    assign product_handle_downcase = product.handle | downcase
    assign product_title_downcase = product.title | downcase

    if product.handle == 'vsling-crossbow-gun-sling' or product.handle == 'untitled-mar22_12-23' or product_handle_downcase contains 'crossbow' or product_handle_downcase contains 'gun-sling' or product_title_downcase contains 'crossbow' or product_title_downcase contains 'gun sling'
      assign seo_page_title = 'Vsling™ Crossbow Sling — Shoot-Ready Treestand Carry'
      assign seo_meta_description = 'The Vsling™ Crossbow/Gun Sling stays on for the shot. 100% elastic, hands-free carry for treestand hunters. Ships with 2 key rings. Made in the USA.'
      assign product_schema_description = 'The Vsling™ Crossbow/Gun Sling is built from the same 100% elastic material that made the original Vsling® famous — now engineered for crossbow and firearm carry. Stays on for the shot. No removal needed. Transfers from carry to shoot in seconds. Ships with two key rings for a custom fit on any setup. Made in Hector, Minnesota, USA.'
      assign seo_meta_keywords = 'crossbow sling, crossbow sling for treestand hunting, hands-free crossbow carrier'
      assign seo_og_title = 'Vsling™ Crossbow Sling — Shoot-Ready Treestand Carry'
      assign seo_og_description = seo_meta_description

    elsif product_handle_downcase contains 'bino' or product_title_downcase contains 'bino'
      assign seo_page_title = product.title | append: ' | Vsling Archery'
      assign seo_meta_description = 'The Vsling Bino Sling keeps your binoculars hands-free and steady with elastic tension that stays quiet and comfortable all day.'
      assign seo_og_title = product.title | append: ' | Vsling Archery'
      assign seo_og_description = seo_meta_description

    elsif product_handle_downcase contains 'bow-sling' or product_title_downcase contains 'bow sling'
      assign seo_page_title = 'Vsling Bow Sling — Hands-Free & Shoot-Ready'
      assign seo_meta_description = 'The Vsling keeps your compound bow hands-free and shoot-ready — elastic, silent, and compatible with all major bow brands.'
      assign product_schema_description = 'The Vsling® is a 100% elastic, patent-pending bow sling that stays on the bow during the shot, requires no removal before drawing, and keeps your compound bow comfortably snug to your body for hands-free carry. Made in Hector, Minnesota, USA.'
      assign seo_meta_keywords = 'bow sling, hands-free bow sling, compound bow sling, bowhunting accessories, bow sling for treestand, elastic bow sling, Vsling archery, shoot-ready bow sling'
      assign seo_og_title = 'Vsling Bow Sling — Draw and Shoot With It On'
      assign seo_og_description = 'The Vsling is the elastic bow sling you never take off — quiet carry, instant draw, and a shot that starts ready.'

    else
      assign seo_page_title = product.title | append: ' | Vsling Archery'
      if product.description != blank
        assign seo_meta_description = product.description | strip_html | strip_newlines | truncate: 155
      endif
      assign seo_og_title = product.title | append: ' | Vsling Archery'
      assign seo_og_description = seo_meta_description
    endif

    assign seo_twitter_title = seo_og_title
    assign seo_twitter_description = seo_og_description

  elsif request.page_type == 'collection'
    assign collection_handle = collection.handle | downcase

    case collection_handle
      when 'all', 'frontpage', 'products'
        assign seo_page_title = 'Bow Slings | Vsling Archery'
        assign seo_meta_description = 'Vsling builds hands-free bow slings, crossbow slings, and hunting gear for bowhunters who want to stay shoot-ready in the stand and on the move.'
        assign seo_og_title = 'Shop Vsling — Hands-Free Hunting Carry'
        assign seo_og_description = 'Every Vsling product is built around one idea: keep your bow or crossbow shoot-ready without the noise, bulk, or hassle of a traditional sling.'
      when 'accessories', 'vsling-accessories'
        assign seo_page_title = 'Bowhunting Accessories | Vsling'
        assign seo_meta_description = 'Vsling accessories let you rep the brand and gear up with the same Minnesota-made team behind the patented shoot-ready bow sling.'
        assign seo_og_title = 'Vsling Accessories'
        assign seo_og_description = seo_meta_description
      when 'bow-slings', 'bow-sling'
        assign seo_page_title = 'Bow Slings | Vsling Archery'
        assign seo_meta_description = 'Every Vsling bow sling is a hands-free, shoot-ready carry system you draw and shoot with — no removal, no dangling straps, no lost time.'
        assign seo_og_title = 'Vsling Bow Slings'
        assign seo_og_description = seo_meta_description
      when 'crossbow-slings', 'crossbow-slings'
        assign seo_page_title = 'Crossbow Slings | Vsling'
        assign seo_meta_description = 'The Vsling crossbow sling keeps your weapon hands-free and shoot-ready through the climb, the wait, and the shot.'
        assign seo_og_title = 'Vsling Crossbow Slings'
        assign seo_og_description = seo_meta_description
      when 'apparel', 'clothing', 'hats', 'shirts'
        assign seo_page_title = 'Vsling Apparel | Archery Gear'
        assign seo_meta_description = 'Vsling apparel is made for bowhunters who already know the difference a shoot-ready sling makes in the field.'
        assign seo_og_title = 'Vsling Archery Apparel'
        assign seo_og_description = seo_meta_description
      else
        assign seo_page_title = collection.title | append: ' | Vsling Archery'
        assign seo_meta_description = 'Shop ' | append: collection.title | append: ' from Vsling Archery — hands-free carry and shoot-ready gear built for serious bowhunters.'
        assign seo_og_title = collection.title | append: ' | Vsling Archery'
        assign seo_og_description = seo_meta_description
    endcase

    assign seo_twitter_title = seo_og_title
    assign seo_twitter_description = seo_og_description

  elsif request.page_type == 'page' and page.handle == 'faq'
    assign seo_page_title = 'Vsling® Bowhunter FAQ | Bow Sling Questions Answered'
    assign seo_meta_description = 'Does the Vsling® get in the way? What bows does it fit? How do you install it? Every question answered — straight from Vsling Archery.'
    assign seo_og_title = 'Vsling® Bowhunter FAQ | Bow Sling Questions Answered'
    assign seo_og_description = 'Does the Vsling® get in the way? What bows does it fit? How do you install it? Every question answered — straight from Vsling Archery.'
    assign seo_twitter_title = seo_og_title
    assign seo_twitter_description = seo_og_description

  elsif request.page_type == 'page' and page.handle == 'vsling-vs-traditional-bow-sling'
    assign seo_page_title = 'Vsling vs Traditional Bow Sling — Why Bowhunters Are Making the Switch'
    assign seo_meta_description = 'Traditional bow slings get in the way. The Vsling® stays on for the shot — 100% elastic, hands-free, and silent. See the full comparison.'
    assign seo_og_title = 'Vsling vs Traditional Bow Sling — Why Bowhunters Are Making the Switch'
    assign seo_og_description = 'Traditional bow slings get in the way. The Vsling® stays on for the shot — 100% elastic, hands-free, and silent. See the full comparison.'
    assign seo_twitter_title = seo_og_title
    assign seo_twitter_description = seo_og_description

  elsif request.page_type == 'page' and page.handle == 'vsling-crossbow-sling-treestand-hunting'
    assign seo_page_title = 'Vsling Crossbow Sling for Treestand Hunting'
    assign seo_meta_description = 'The Vsling™ crossbow sling keeps your weapon hands-free and shoot-ready on the climb, in the stand, and at the shot. Made in the USA.'
    assign seo_meta_keywords = 'crossbow sling, crossbow sling for treestand hunting, hands-free crossbow carrier, treestand crossbow sling'
    assign seo_og_title = 'Vsling Crossbow Sling for Treestand Hunting'
    assign seo_og_description = seo_meta_description
    assign seo_twitter_title = seo_og_title
    assign seo_twitter_description = seo_og_description
  endif
-%}
