{%- comment -%}
  Appends the Bowhunter FAQ page to header navigation when the main menu
  does not already link to /pages/faq.

  Accepts:
    menu_style: 'drawer' | 'inline'
{%- endcomment -%}

{%- liquid
  assign vsling_faq_page_handle = 'faq'
  assign vsling_faq_page = pages[vsling_faq_page_handle]
  assign vsling_faq_url = vsling_faq_page.url | default: '/pages/faq'
  assign faq_fallback_url = '/pages/faq'
  assign show_faq_nav = true

  for link in section.settings.menu.links
    if link.url == vsling_faq_url or link.url == faq_fallback_url
      assign show_faq_nav = false
    endif
    for childlink in link.links
      if childlink.url == vsling_faq_url or childlink.url == faq_fallback_url
        assign show_faq_nav = false
      endif
      for grandchildlink in childlink.links
        if grandchildlink.url == vsling_faq_url or grandchildlink.url == faq_fallback_url
          assign show_faq_nav = false
        endif
      endfor
    endfor
  endfor

  assign faq_nav_active = false
  if request.page_type == 'page' and page.handle == vsling_faq_page_handle
    assign faq_nav_active = true
  endif
-%}

{%- if show_faq_nav -%}
  {%- if menu_style == 'drawer' -%}
    <li>
      <a
        id="HeaderDrawer-faq"
        href="{{ vsling_faq_url }}"
        class="menu-drawer__menu-item list-menu__item link link--text focus-inset{% if faq_nav_active %} menu-drawer__menu-item--active{% endif %}"
        {% if faq_nav_active %}
          aria-current="page"
        {% endif %}
      >
        Bowhunter FAQ
      </a>
    </li>
  {%- else -%}
    <li>
      <a
        id="HeaderMenu-faq"
        href="{{ vsling_faq_url }}"
        class="header__menu-item list-menu__item link link--text focus-inset"
        {% if faq_nav_active %}
          aria-current="page"
        {% endif %}
      >
        <span{% if faq_nav_active %} class="header__active-menu-item"{% endif %}>
          Bowhunter FAQ
        </span>
      </a>
    </li>
  {%- endif -%}
{%- endif -%}
