{%- comment -%}
  Loads Menseal Black for headings/header. Body font uses theme Montserrat setting.
{%- endcomment -%}

{% style %}
  @font-face {
    font-family: 'Menseal';
    src: url('{{ 'menseal-regular.ttf' | asset_url }}') format('truetype');
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: 'Menseal';
    src: url('{{ 'menseal-black.ttf' | asset_url }}') format('truetype');
    font-weight: 900;
    font-style: normal;
    font-display: swap;
  }

  :root {
    --font-heading-family: 'Menseal', sans-serif;
    --font-heading-style: normal;
    --font-heading-weight: 900;
  }

  .header__heading,
  .header__heading-link,
  .header__menu-item,
  .header__menu-item span,
  .header__active-menu-item,
  .menseal-heading,
  #SiteFaqHeading {
    font-family: var(--font-heading-family);
    font-style: var(--font-heading-style);
    font-weight: var(--font-heading-weight);
  }

  .comparison__hero .banner__heading,
  .comparison__hero .banner__heading.h0,
  #ComparisonHeading,
  #ComparisonHeading.h0 {
    font-family: 'Menseal', sans-serif;
    font-style: normal;
    font-weight: 400;
    letter-spacing: normal;
  }
{% endstyle %}
