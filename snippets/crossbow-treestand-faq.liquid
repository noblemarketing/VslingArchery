{%- comment -%}
  FAQ accordion and FAQPage JSON-LD for the crossbow treestand landing page.

  Usage:
    {% render 'crossbow-treestand-faq', section_id: section.id, render_part: 'accordion' %}
    {% render 'crossbow-treestand-faq', section_id: section.id, render_part: 'schema' %}
{%- endcomment -%}

{%- include 'crossbow-treestand-data' -%}

{%- if render_part == 'accordion' -%}
  <div class="site-faq crossbow-treestand__faq" data-site-faq>
    {%- for question in ct_questions -%}
      {%- assign answer_plain = ct_answers[forloop.index0] -%}
      {%- assign global_index = forloop.index -%}
      <details class="site-faq__item accordion" id="Details-CrossbowTreestandFAQ-{{ global_index }}-{{ section_id }}">
        <summary id="Summary-CrossbowTreestandFAQ-{{ global_index }}-{{ section_id }}">
          <div class="site-faq__summary-inner">
            <h3 class="site-faq__question">{{ question | escape }}</h3>
            <span class="site-faq__toggle-icon" aria-hidden="true">+</span>
          </div>
        </summary>
        <div class="site-faq__panel">
          <div class="site-faq__panel-inner">
            <p
              class="site-faq__answer rte"
              {% if global_index == 1 %}id="CrossbowTreestandFirstAnswer"{% endif %}
            >
              {{ answer_plain | escape }}
            </p>
          </div>
        </div>
      </details>
    {%- endfor -%}
  </div>
{%- elsif render_part == 'schema' -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {%- for question in ct_questions -%}
          {%- assign answer_plain = ct_answers[forloop.index0] -%}
          {
            "@type": "Question",
            "name": {{ question | json }},
            "acceptedAnswer": {
              "@type": "Answer",
              "text": {{ answer_plain | json }}
            }
          }{%- unless forloop.last -%},{%- endunless -%}
        {%- endfor -%}
      ]
    }
  </script>
{%- endif -%}
