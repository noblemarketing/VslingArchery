    <section id="{{ cat_5_id }}" class="site-faq__category">
      <h2 class="h1 site-faq__category-title">{{ cat_5_title }}</h2>
      {%- assign questions = s_q1 | append: '~~~' | append: s_q2 | append: '~~~' | append: s_q3 | append: '~~~' | append: s_q4 | split: '~~~' -%}
      {%- assign answers = s_a1_plain | append: '~~~' | append: s_a2_plain | append: '~~~' | append: s_a3_plain | append: '~~~' | append: s_a4_plain | split: '~~~' -%}
      {%- for question in questions -%}
        {%- assign answer_plain = answers[forloop.index0] -%}
        {%- assign global_index = forloop.index | plus: 21 -%}
        {%- include 'site-faq-answer-html', answer_plain: answer_plain, global_index: global_index -%}
        <details class="site-faq__item accordion" id="Details-SiteFAQ-{{ global_index }}-{{ section_id }}">
          <summary id="Summary-SiteFAQ-{{ global_index }}-{{ section_id }}">
            <div class="site-faq__summary-inner">
              <h3 class="site-faq__question">{{ question | escape }}</h3>
              <span class="site-faq__toggle-icon" aria-hidden="true">+</span>
            </div>
          </summary>
          <div class="site-faq__panel">
            <div class="site-faq__panel-inner">
              <p class="site-faq__answer rte">{{ answer_html }}</p>
            </div>
          </div>
        </details>
      {%- endfor -%}
    </section>
  </site-faq>
{%- endif -%}

{%- if render_part == 'schema' -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {%- for question in faq_questions -%}
        {
          "@type": "Question",
          "name": {{ question | json }},
          "acceptedAnswer": {
            "@type": "Answer",
            "text": {{ faq_answers_plain[forloop.index0] | json }}
          }
        }{%- unless forloop.last -%},{%- endunless -%}
        {%- endfor -%}
      ]
    }
  </script>

  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebPage",
      "name": "Vsling® Bowhunter FAQ",
      "speakable": {
        "@type": "SpeakableSpecification",
        "cssSelector": ["#SiteFaqHeading", "#SiteFaqFirstAnswer"]
      }
    }
  </script>
{%- endif -%}
