{%- comment -%}
  Renders site FAQ accordion, FAQPage JSON-LD, and Speakable schema for /pages/faq.

  Usage:
    {% render 'site-faq', section_id: section.id, render_part: 'accordion' %}
    {% render 'site-faq', section_id: section.id, render_part: 'schema' %}
{%- endcomment -%}

{%- include 'site-faq-data' -%}

{%- if render_part == 'accordion' -%}
  <site-faq class="site-faq" data-site-faq>
    <section id="{{ cat_1_id }}" class="site-faq__category">
      <h2 class="h1 site-faq__category-title">{{ cat_1_title }}</h2>
      {%- assign questions = p_q1 | append: '~~~' | append: p_q2 | append: '~~~' | append: p_q3 | append: '~~~' | append: p_q4 | append: '~~~' | append: p_q5 | append: '~~~' | append: p_q6 | append: '~~~' | append: p_q7 | split: '~~~' -%}
      {%- assign answers = p_a1_plain | append: '~~~' | append: p_a2_plain | append: '~~~' | append: p_a3_plain | append: '~~~' | append: p_a4_plain | append: '~~~' | append: p_a5_plain | append: '~~~' | append: p_a6_plain | append: '~~~' | append: p_a7_plain | split: '~~~' -%}
      {%- for question in questions -%}
        {%- assign answer_plain = answers[forloop.index0] -%}
        {%- assign global_index = forloop.index -%}
        {%- include 'site-faq-answer-html', answer_plain: answer_plain, global_index: global_index -%}
        <details class="site-faq__item accordion" id="Details-SiteFAQ-{{ global_index }}-{{ section_id }}">
          <summary id="Summary-SiteFAQ-{{ global_index }}-{{ section_id }}">
            <div class="site-faq__summary-inner">
              <h3 class="site-faq__question">{{ question | escape }}</h3>
              <span class="site-faq__toggle-icon" aria-hidden="true">+</span>
            </div>
          </summary>
          <div class="site-faq__panel">
            <div class="site-faq__panel-inner">
              <div
                class="site-faq__answer rte"
                {% if global_index == 1 %}id="SiteFaqFirstAnswer"{% endif %}
              >
                {{ answer_html }}
              </div>
            </div>
          </div>
        </details>
      {%- endfor -%}
    </section>

    <section id="{{ cat_2_id }}" class="site-faq__category">
      <h2 class="h1 site-faq__category-title">{{ cat_2_title }}</h2>
      {%- assign questions = c_q1 | append: '~~~' | append: c_q2 | append: '~~~' | append: c_q3 | append: '~~~' | append: c_q4 | append: '~~~' | append: c_q5 | append: '~~~' | append: c_q6 | append: '~~~' | append: c_q7 | split: '~~~' -%}
      {%- assign answers = c_a1_plain | append: '~~~' | append: c_a2_plain | append: '~~~' | append: c_a3_plain | append: '~~~' | append: c_a4_plain | append: '~~~' | append: c_a5_plain | append: '~~~' | append: c_a6_plain | append: '~~~' | append: c_a7_plain | split: '~~~' -%}
      {%- for question in questions -%}
        {%- assign answer_plain = answers[forloop.index0] -%}
        {%- assign global_index = forloop.index | plus: 7 -%}
        {%- include 'site-faq-answer-html', answer_plain: answer_plain, global_index: global_index -%}
        <details class="site-faq__item accordion" id="Details-SiteFAQ-{{ global_index }}-{{ section_id }}">
          <summary id="Summary-SiteFAQ-{{ global_index }}-{{ section_id }}">
            <div class="site-faq__summary-inner">
              <h3 class="site-faq__question">{{ question | escape }}</h3>
              <span class="site-faq__toggle-icon" aria-hidden="true">+</span>
            </div>
          </summary>
          <div class="site-faq__panel">
            <div class="site-faq__panel-inner">
              <div class="site-faq__answer rte">{{ answer_html }}</div>
            </div>
          </div>
        </details>
      {%- endfor -%}
    </section>

    <section id="{{ cat_3_id }}" class="site-faq__category">
      <h2 class="h1 site-faq__category-title">{{ cat_3_title }}</h2>
      {%- assign questions = i_q1 | append: '~~~' | append: i_q2 | append: '~~~' | append: i_q3 | append: '~~~' | append: i_q4 | split: '~~~' -%}
      {%- assign answers = i_a1_plain | append: '~~~' | append: i_a2_plain | append: '~~~' | append: i_a3_plain | append: '~~~' | append: i_a4_plain | split: '~~~' -%}
      {%- for question in questions -%}
        {%- assign answer_plain = answers[forloop.index0] -%}
        {%- assign global_index = forloop.index | plus: 14 -%}
        {%- include 'site-faq-answer-html', answer_plain: answer_plain, global_index: global_index -%}
        <details class="site-faq__item accordion" id="Details-SiteFAQ-{{ global_index }}-{{ section_id }}">
          <summary id="Summary-SiteFAQ-{{ global_index }}-{{ section_id }}">
            <div class="site-faq__summary-inner">
              <h3 class="site-faq__question">{{ question | escape }}</h3>
              <span class="site-faq__toggle-icon" aria-hidden="true">+</span>
            </div>
          </summary>
          <div class="site-faq__panel">
            <div class="site-faq__panel-inner">
              <div class="site-faq__answer rte">{{ answer_html }}</div>
            </div>
          </div>
        </details>
      {%- endfor -%}
    </section>

    <section id="{{ cat_4_id }}" class="site-faq__category">
      <h2 class="h1 site-faq__category-title">{{ cat_4_title }}</h2>
      {%- assign questions = f_q1 | append: '~~~' | append: f_q2 | append: '~~~' | append: f_q3 | append: '~~~' | append: f_q4 | append: '~~~' | append: f_q5 | split: '~~~' -%}
      {%- assign answers = f_a1_plain | append: '~~~' | append: f_a2_plain | append: '~~~' | append: f_a3_plain | append: '~~~' | append: f_a4_plain | append: '~~~' | append: f_a5_plain | split: '~~~' -%}
      {%- for question in questions -%}
        {%- assign answer_plain = answers[forloop.index0] -%}
        {%- assign global_index = forloop.index | plus: 18 -%}
        {%- include 'site-faq-answer-html', answer_plain: answer_plain, global_index: global_index -%}
        <details class="site-faq__item accordion" id="Details-SiteFAQ-{{ global_index }}-{{ section_id }}">
          <summary id="Summary-SiteFAQ-{{ global_index }}-{{ section_id }}">
            <div class="site-faq__summary-inner">
              <h3 class="site-faq__question">{{ question | escape }}</h3>
              <span class="site-faq__toggle-icon" aria-hidden="true">+</span>
            </div>
          </summary>
          <div class="site-faq__panel">
            <div class="site-faq__panel-inner">
              <div class="site-faq__answer rte">{{ answer_html }}</div>
            </div>
          </div>
        </details>
      {%- endfor -%}
    </section>
  </site-faq>
{%- endif -%}

{%- if render_part == 'schema' -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": {{ schema_q1 | json }},
          "acceptedAnswer": {
            "@type": "Answer",
            "text": {{ schema_a1 | json }}
          }
        },
        {
          "@type": "Question",
          "name": {{ schema_q2 | json }},
          "acceptedAnswer": {
            "@type": "Answer",
            "text": {{ schema_a2 | json }}
          }
        },
        {
          "@type": "Question",
          "name": {{ schema_q3 | json }},
          "acceptedAnswer": {
            "@type": "Answer",
            "text": {{ schema_a3 | json }}
          }
        },
        {
          "@type": "Question",
          "name": {{ schema_q4 | json }},
          "acceptedAnswer": {
            "@type": "Answer",
            "text": {{ schema_a4 | json }}
          }
        },
        {
          "@type": "Question",
          "name": {{ schema_q5 | json }},
          "acceptedAnswer": {
            "@type": "Answer",
            "text": {{ schema_a5 | json }}
          }
        },
        {
          "@type": "Question",
          "name": {{ schema_q6 | json }},
          "acceptedAnswer": {
            "@type": "Answer",
            "text": {{ schema_a6 | json }}
          }
        },
        {
          "@type": "Question",
          "name": {{ schema_q7 | json }},
          "acceptedAnswer": {
            "@type": "Answer",
            "text": {{ schema_a7 | json }}
          }
        },
        {
          "@type": "Question",
          "name": {{ schema_q8 | json }},
          "acceptedAnswer": {
            "@type": "Answer",
            "text": {{ schema_a8 | json }}
          }
        }
      ]
    }
  </script>

  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebPage",
      "name": "Vsling® Bowhunter FAQ",
      "speakable": {
        "@type": "SpeakableSpecification",
        "cssSelector": ["#SiteFaqHeading", "#SiteFaqFirstAnswer"]
      }
    }
  </script>
{%- endif -%}
