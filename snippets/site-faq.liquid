{%- comment -%}
  Renders site FAQ accordion and FAQPage JSON-LD for /pages/faq.

  Usage:
    {% render 'site-faq', section_id: section.id, render_part: 'accordion' %}
    {% render 'site-faq', section_id: section.id, render_part: 'schema' %}
{%- endcomment -%}

{%- include 'site-faq-data' -%}

{%- if render_part == 'accordion' -%}
  <div class="site-faq">
    {%- for question in faq_questions -%}
      {%- assign answer = faq_answers[forloop.index0] -%}
      {%- if forloop.index == 1 -%}
        <h2 class="h2 site-faq__group-title">{{ group_1_title }}</h2>
        <p class="site-faq__product-link">
          <a href="{{ bow_product_url }}">Shop the hands-free Vsling compound bow sling</a>
        </p>
        <p class="site-faq__product-link">
          <a href="{{ comparison_page_url }}">Vsling vs traditional bow sling comparison</a>
        </p>
      {%- elsif forloop.index == 9 -%}
        <h2 class="h2 site-faq__group-title">{{ group_2_title }}</h2>
        <p class="site-faq__product-link">
          <a href="{{ crossbow_product_url }}">Shop the Vsling crossbow sling for treestand hunting</a>
        </p>
      {%- elsif forloop.index == 16 -%}
        <h2 class="h2 site-faq__group-title">{{ group_3_title }}</h2>
        <p class="site-faq__product-link">
          <a href="{{ all_products_url }}">Browse all Vsling bowhunting accessories</a>
        </p>
      {%- endif -%}
      <div class="product__accordion accordion">
        <details id="Details-SiteFAQ-{{ forloop.index }}-{{ section_id }}">
          <summary id="Summary-SiteFAQ-{{ forloop.index }}-{{ section_id }}">
            <div class="summary__title">
              {% render 'icon-accordion', icon: 'question_mark' %}
              <h3 class="h4 accordion__title inline-richtext">{{ question | escape }}</h3>
            </div>
            {{- 'icon-caret.svg' | inline_asset_content -}}
          </summary>
          <div
            class="accordion__content rte"
            role="region"
            aria-labelledby="Summary-SiteFAQ-{{ forloop.index }}-{{ section_id }}"
          >
            <p>{{ answer | escape }}</p>
          </div>
        </details>
      </div>
    {%- endfor -%}
  </div>
{%- endif -%}

{%- if render_part == 'schema' -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {%- for question in faq_questions -%}
        {
          "@type": "Question",
          "name": {{ question | json }},
          "acceptedAnswer": {
            "@type": "Answer",
            "text": {{ faq_answers[forloop.index0] | json }}
          }
        }{%- unless forloop.last -%},{%- endunless -%}
        {%- endfor -%}
      ]
    }
  </script>
{%- endif -%}
