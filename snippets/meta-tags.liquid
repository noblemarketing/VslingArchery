{%- include 'seo-meta-data' -%}

{%- liquid
  assign og_url = canonical_url | default: request.origin
  assign og_type = 'website'

  if template.name == 'index'
    assign og_title = 'Vsling® Bow Sling | Hands-Free, Shoot-With-It-On Carry'
  elsif seo_og_title != blank
    assign og_title = seo_og_title
  elsif request.page_type == 'page' and page.handle == 'vsling-vs-traditional-bow-sling'
    assign og_title = 'Vsling vs Traditional Bow Sling — Why Bowhunters Are Making the Switch'
  elsif request.page_type == 'page' and page.handle == 'faq'
    assign og_title = 'Vsling® Bowhunter FAQ | Bow Sling Questions Answered'
  elsif request.page_type == 'page' and page.title != blank
    assign og_title = page.title
  elsif seo_page_title != blank
    assign og_title = seo_page_title
  else
    assign og_title = page_title | default: shop.name
  endif

  if seo_og_description != blank
    assign og_description = seo_og_description
  elsif seo_meta_description != blank
    assign og_description = seo_meta_description
  elsif request.page_type == 'index'
    assign og_description = 'The Vsling® is the only bow sling you can shoot with on. 100% elastic, hands-free, and silent. Its quiet, flexible design keeps your compound bow snug and shoot-ready. Made in Minnesota, USA.'
  elsif request.page_type == 'page' and page.handle == 'vsling-vs-traditional-bow-sling'
    assign og_description = 'Traditional bow slings get in the way. The Vsling® stays on for the shot — 100% elastic, hands-free, and silent. Pair with the Vsling bino sling for full hands-free carry.'
  elsif request.page_type == 'page' and page.handle == 'faq'
    assign og_description = 'Does the Vsling® get in the way? What bows does it fit? How do you install it? Bow sling, crossbow sling, and bino sling questions answered — straight from Vsling Archery.'
  elsif request.page_type == 'page' and page_description != blank
    assign og_description = page_description
  else
    assign og_description = page_description | default: shop.name
  endif

  if template.name == 'index'
    assign twitter_title = 'Vsling® Bow Sling | Hands-Free, Shoot-With-It-On Carry'
  elsif seo_twitter_title != blank
    assign twitter_title = seo_twitter_title
  else
    assign twitter_title = og_title
  endif

  if seo_twitter_description != blank
    assign twitter_description = seo_twitter_description
  else
    assign twitter_description = og_description
  endif

  if request.page_type == 'product'
    assign og_type = 'product'
  elsif request.page_type == 'article'
    assign og_type = 'article'
  elsif request.page_type == 'password'
    assign og_url = request.origin
  endif
-%}

<meta property="og:site_name" content="{{ shop.name }}">
<meta property="og:url" content="{{ og_url }}">
<meta property="og:title" content="{{ og_title | escape }}">
<meta property="og:type" content="{{ og_type }}">
<meta property="og:description" content="{{ og_description | escape }}">

{%- if page_image -%}
  <meta property="og:image" content="http:{{ page_image | image_url }}">
  <meta property="og:image:secure_url" content="https:{{ page_image | image_url }}">
  <meta property="og:image:width" content="{{ page_image.width }}">
  <meta property="og:image:height" content="{{ page_image.height }}">
{%- endif -%}

{%- if request.page_type == 'product' -%}
  <meta property="og:price:amount" content="{{ product.price | money_without_currency | strip_html }}">
  <meta property="og:price:currency" content="{{ cart.currency.iso_code }}">
{%- endif -%}

{%- if settings.social_twitter_link != blank -%}
  <meta name="twitter:site" content="{{ settings.social_twitter_link | split: 'twitter.com/' | last | prepend: '@' }}">
{%- endif -%}
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ twitter_title | escape }}">
<meta name="twitter:description" content="{{ twitter_description | escape }}">

{%- if page_image -%}
  <meta name="twitter:image" content="https:{{ page_image | image_url }}">
{%- endif -%}
